@* SVG background grid pattern *@
<defs>
    <pattern id="smallGrid" width="20" height="20" patternUnits="userSpaceOnUse">
        <path d="M 20 0 L 0 0 0 20" fill="none" stroke="rgba(48,54,61,0.4)" stroke-width="0.5" />
    </pattern>
    <pattern id="largeGrid" width="100" height="100" patternUnits="userSpaceOnUse">
        <rect width="100" height="100" fill="url(#smallGrid)" />
        <path d="M 100 0 L 0 0 0 100" fill="none" stroke="rgba(48,54,61,0.8)" stroke-width="1" />
    </pattern>
</defs>
<rect width="10000" height="10000" x="-5000" y="-5000" fill="var(--bg-canvas)" />
<rect width="10000" height="10000" x="-5000" y="-5000" fill="url(#largeGrid)" />
